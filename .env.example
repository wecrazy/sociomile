COMPOSE_PROJECT_NAME=sociomile

MYSQL_DATABASE=sociomile
MYSQL_USER=sociomile
MYSQL_PASSWORD=sociomile
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=13306

REDIS_PORT=16379

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

BACKEND_PORT=8080
FRONTEND_PORT=5173

JWT_SECRET=sociomile-local-dev-secret
ACCESS_TOKEN_TTL=15m

APP_ENV=development
LOG_LEVEL=debug